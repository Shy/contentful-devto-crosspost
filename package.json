{
  "name": "contentful-devto-crosspost",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build && contentful-app-scripts build-functions --ci --manifest-file contentful-app-manifest.json --esbuild-config esbuild.functions.cjs && node scripts/copy-functions.mjs",
    "build:functions": "contentful-app-scripts build-functions --ci --manifest-file contentful-app-manifest.json --esbuild-config esbuild.functions.cjs && node scripts/copy-functions.mjs",
    "typecheck": "tsc -b",
    "dev:payload": "tsx scripts/dev-payload.ts",
    "contentful:upload": "contentful-app-scripts upload --bundle-dir ./dist"
  },
  "dependencies": {
    "@contentful/app-sdk": "^4.57.0",
    "@contentful/node-apps-toolkit": "^4.0.0",
    "@contentful/react-apps-toolkit": "^2.0.1",
    "@vitejs/plugin-react": "^5.1.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "tsx": "^4.20.6",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@contentful/app-scripts": "^3.0.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.4"
  }
}
