# Contentful GraphQL Content API
CONTENTFUL_SPACE_ID=
CONTENTFUL_ENVIRONMENT_ID=master
CONTENTFUL_DELIVERY_TOKEN=
CONTENTFUL_PREVIEW_TOKEN=
CONTENTFUL_USE_PREVIEW=true

# Optional: only needed for exact content model metadata from the CMA.
CONTENTFUL_MANAGEMENT_TOKEN=

# Public blog canonical URL base.
SITE_BLOG_BASE_URL=https://example.com/blog

# DEV/Forem org target. Leave empty to post to the user's personal account.
DEVTO_ORG_USERNAME=
DEVTO_ORG_ID=

# Optional: only needed if you want scripts to call DEV locally.
DEVTO_API_KEY=
